# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
.utmp/
**/[Ll]ibrary/
**/[Tt]emp/
**/[Oo]bj/
**/[Bb]uild/
**/[Bb]uilds/
**/[Ll]ogs/
**/[Uu]ser[Ss]ettings/
*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
*.blend1
*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
*.DotSettings.user

# Visual Studio cache directory
.vs/
.vscode/

# Visual Studio cache directory
.vscode/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono auto generated files
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# TestRunner generated files
InitTestScene*.unity*

# Addressables default ignores, before user customizations
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/Assets/StreamingAssets/
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/Assets/[Ss]treamingAssets/[Aa]ssemblyCSharp.dll
/Assets/[Ss]treamingAssets/[Aa]ssemblyCSharp-Editor.dll
/Assets/[Ss]treamingAssets/[Mm]etaData/
/Assets/[Ss]treamingAssets/[Tt]emp/
#/Assets/Wwise/API/Runtime/Plugins/Mac/
#/Assets/Wwise/API/Runtime/Plugins/Windows/
/Packages/
/GeneratedLocalIl2CppFiles/
Assets/Wwise/Resources

# Files
/*.csproj
/*.unityproj
/*.sln
/*.suo
/*.user
/*.userprefs
/*.pidb
/*.booproj
/*.svd
/*.dll.meta
/*.pdb.meta
/*.mdb.meta
/*.rsp
/*.lnk
/*.DS_Store # macOS specific file
/Thumbs.db # Windows specific file
/UnityCrashHandler_*.exe

# Memory Captures
/*.hprof

# Optional: Ignore all Wwise Unity Integration Plugins folder and manage deployment via Wwise Launcher
# If you ignore these, all team members must use the Wwise Launcher to install the correct platform plugins locally.
# /Assets/Wwise/API/Runtime/Plugins/

# === Wwise Exclusions ===
# Wwise generated files and cache data
# Audiokinetic documentation source:

# Wwise Project Cache (essential to ignore)
*.cache*
*.akd 
*.validationcache
IncrementalSoundBankData.xml

# Wwise Backup files
*.backup*
*.wsettings

# Optional: Ignore generated sound banks in the Wwise project path if managed separately.
#Wwise/GeneratedSoundBanks/

# Exclude Wwise Unity-specific temporary data file (AkWwiseProjectData.asset)
# This file is a cache for the Wwise Picker and is regenerated locally.
Assets/AkWwiseProjectData.asset

*.crossover.validationcache
*.crossover.wsettings
#GeneratedSoundBanks/